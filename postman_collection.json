    {
      "name": "TEST 5: Filter by SubjectId",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_JWT_TOKEN_HERE",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/teacher/students?subjectId=1",
          "protocol": "http",
          "host": ["localhost"],
