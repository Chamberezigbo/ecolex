        "url": {
          "raw": "http://localhost:3000/api/teacher/students?academicSessionId=1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "teacher", "students"],
          "query": [
            {
              "key": "academicSessionId",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "TEST 4: Filter by ClassGroupId",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_JWT_TOKEN_HERE",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/teacher/students?classGroupId=1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "teacher", "students"],
          "query": [
            {
              "key": "classGroupId",
              "value": "1"
            }
