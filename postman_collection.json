{
  "info": {
    "name": "Ecolex Teacher API - Students Endpoint",
    "description": "Examples for the new GET /api/teacher/students endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "TEST 1: Get All Students",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_JWT_TOKEN_HERE",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/teacher/students",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "teacher", "students"]
        }
      }
    },
    {
      "name": "TEST 2: Filter by ClassId",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_JWT_TOKEN_HERE",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/teacher/students?classId=1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "teacher", "students"],
          "query": [
            {
              "key": "classId",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "TEST 3: Filter by Academic Session",
      "request": {
        "method": "GET",
        "header": [
          {
