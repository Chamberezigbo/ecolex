          "path": ["api", "teacher", "students"],
          "query": [
            {
              "key": "subjectId",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "TEST 6: Multiple Filters Combined",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_JWT_TOKEN_HERE",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/teacher/students?classId=1&academicSessionId=1&subjectId=1",
